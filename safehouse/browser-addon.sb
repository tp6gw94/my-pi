    (global-name-regex #"^org\.chromium\.Chromium\.MachPortRendezvousServer\.")
    (global-name-regex #"^org\.chromium\.crashpad\.child_port_handshake\.")
    (global-name-regex #"^com\.google\.Chrome\.MachPortRendezvousServer\.")
