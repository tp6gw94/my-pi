(allow file-read* file-write*
    (home-subpath "/Library/Application Support/Google/Chrome/Crashpad")
)
(allow file-read-xattr file-write-xattr
    (home-subpath "/Library/Application Support/Google/Chrome/Crashpad")
)

(allow system-fsctl
    (fsctl-command (_IO "h" 47))
)

(allow iokit-open
    (iokit-user-client-class "RootDomainUserClient")
    (iokit-user-client-class "IOHIDParamUserClient")
    (iokit-user-client-class "AppleNVMeEANUC")
    (iokit-user-client-class "IOSurfaceRootUserClient")
    (iokit-user-client-class "AGXDeviceUserClient")
)

;; ---------------------------------------------------------------------------
;; Integration: Chromium Full
;; ---------------------------------------------------------------------------
(allow file-read-metadata
    (home-literal "/Library/Application Support/Google")
    (home-literal "/Library/Application Support/Google/Chrome")
    (home-literal "/Library/Application Support/Google/Chrome/Crashpad")
    (home-literal "/Library/Application Support/Google/Chrome for Testing")
    (home-literal "/Library/Application Support/Google/Chrome for Testing/Crashpad")
    (home-literal "/Library/Google")
)

(allow file-read*
    (literal "/Applications")
    (subpath "/Applications/Google Chrome.app")
    (subpath "/Applications/cmux.app")
    (literal "/System")
    (literal "/System/Volumes")
    (literal "/System/Volumes/Data")
    (literal "/System/Volumes/Data/Applications")
    (subpath "/System/Volumes/Data/Applications/Google Chrome.app")
    (subpath "/System/Volumes/Data/Applications/cmux.app")
    (literal "/Library")
    (home-literal "/Library/Preferences/com.google.Chrome.plist")
    (home-literal "/Library/Preferences/com.google.chrome.for.testing.plist")
    (home-literal "/Library/Google/Google Chrome Brand.plist")
)

(allow file-read* file-write*
    (home-literal "/Library/Application Support/Google/Chrome/DevToolsActivePort")
    (home-subpath "/Library/Application Support/Google/Chrome/Crashpad")
    (home-subpath "/Library/Application Support/Google/Chrome for Testing/Crashpad")
)
(allow file-read-xattr file-write-xattr
    (home-subpath "/Library/Application Support/Google/Chrome for Testing/Crashpad")
)

(allow mach-register
    (global-name-regex #"^com\.google\.Chrome\.MachPortRendezvousServer\.")
    (global-name-regex #"^com\.google\.Chrome\.crashpad\.child_port_handshake\.")
    (global-name-regex #"^com\.google\.chrome\.for\.testing\.MachPortRendezvousServer\.")
    (global-name-regex #"^com\.google\.chrome\.for\.testing\.crashpad\.child_port_handshake\.")
)

(allow mach-lookup
    (global-name-regex #"^com\.google\.Chrome\.MachPortRendezvousServer\.")
    (global-name-regex #"^com\.google\.Chrome\.crashpad\.child_port_handshake\.")
    (global-name-regex #"^com\.google\.chrome\.for\.testing\.MachPortRendezvousServer\.")
    (global-name-regex #"^com\.google\.chrome\.for\.testing\.crashpad\.child_port_handshake\.")
    (global-name "com.apple.pasteboard.1")
    (global-name "com.apple.system.opendirectoryd.api")
    (global-name "com.apple.ctkd.token-client")
)

;; ---------------------------------------------------------------------------
;; Integration: Agent Browser
;; ---------------------------------------------------------------------------
(allow file-read* file-write*
    (home-literal "")                                                 ;; Traverse HOME when workdir is outside $HOME and the CLI probes ~/.agent-browser directly.
    (home-literal "/.agent-browser")                                  ;; Directory entry access for direct stat/readdir calls on ~/.agent-browser.
    (home-subpath "/.agent-browser")
)

(allow file-read-metadata
    (home-literal "/Library")                                         ;; pnpm-installed shims under ~/Library/pnpm require ancestor traversal during Node entrypoint resolution.
    (home-literal "/Library/pnpm")
)
