#!/usr/bin/env bash
set -euo pipefail

# Custom sandbox wrapper for Pi.
# Mirrors Agent Safehouse assembly but uses a static base profile, appends
# the browser addon by default, and appends the invocation directory as a
# read/write workdir at launch time.

BASE_PROFILE="${BASE_PROFILE:-$HOME/.pi/safehouse/custom-pi.sb}"
BROWSER_ADDON="${BROWSER_ADDON:-$HOME/.pi/safehouse/browser-addon.sb}"
KEYCHAIN_ADDON="${KEYCHAIN_ADDON:-$HOME/.pi/safehouse/keychain-addon.sb}"

if [[ ! -f "$BASE_PROFILE" ]]; then
  echo "Base profile not found: $BASE_PROFILE" >&2
  exit 1
fi

if [[ ! -f "$BROWSER_ADDON" ]]; then
  echo "Browser addon not found: $BROWSER_ADDON" >&2
  exit 1
fi

WORKDIR="$(pwd -P)"

# Escape a string for use inside an SBPL double-quoted string.
_sb_escape() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  printf '%s' "$s"
}

# Emit file-read* literal rules for every ancestor of $WORKDIR (including /).
# This matches Safehouse's emit_path_ancestor_literals() behavior.
_emit_workdir_ancestors() {
  local path="$1"
  local trimmed current=""

  printf '    (literal "/")\n'

  trimmed="${path#/}"
  if [[ -n "$trimmed" ]]; then
    local IFS='/'
    local -a parts=()
    read -r -a parts <<< "$trimmed"
    for part in "${parts[@]}"; do
      [[ -z "$part" ]] && continue
      current="${current}/${part}"
      printf '    (literal "%s")\n' "$(_sb_escape "$current")"
    done
  fi
}

# If the current directory is a linked git worktree, print the absolute path
# of the main (original) worktree. Returns nothing for normal checkouts,
# bare repos, or when git is unavailable.
_detect_main_worktree() {
  local git_dir git_common_dir superproject main_worktree

  git_dir="$(git rev-parse --git-dir 2>/dev/null || true)"
  git_common_dir="$(git rev-parse --git-common-dir 2>/dev/null || true)"
  superproject="$(git rev-parse --show-superproject-working-tree 2>/dev/null || true)"

  # Same git-dir and common-dir means a normal checkout (or submodule).
  # A non-empty superproject path means we are inside a submodule, not a worktree.
  if [[ -z "$git_dir" || -z "$git_common_dir" || "$git_dir" == "$git_common_dir" || -n "$superproject" ]]; then
    return 0
  fi

  # The first entry from `git worktree list --porcelain` is always the main worktree.
  main_worktree="$(git worktree list --porcelain 2>/dev/null | awk '/^worktree / {print $2; exit}')"

  # Fallback for unusual git-dir layouts: the main checkout usually sits
  # directly above the shared common git dir.
  if [[ -z "$main_worktree" ]]; then
    main_worktree="${git_common_dir%/*}"
  fi

  if [[ -n "$main_worktree" && -d "$main_worktree" ]]; then
    (cd "$main_worktree" && pwd -P)
  fi
}

TMP_POLICY="$(mktemp "${TMPDIR:-/tmp}/safe-pi-policy.XXXXXX")"
trap 'rm -f "$TMP_POLICY"' EXIT

cp "$BASE_PROFILE" "$TMP_POLICY"

{
  cat <<EOF

;; ---------------------------------------------------------------------------
;; Browser addon (loaded by default)
;; Source: ${BROWSER_ADDON}
;; ---------------------------------------------------------------------------
EOF
  cat "$BROWSER_ADDON"
} >> "$TMP_POLICY"

# Append keychain addon if present (read-only, may not exist on all setups).
if [[ -f "$KEYCHAIN_ADDON" ]]; then
{
  cat <<EOF

;; ---------------------------------------------------------------------------
;; Keychain addon (loaded by default if the addon file exists)
;; Source: ${KEYCHAIN_ADDON}
;; ---------------------------------------------------------------------------
EOF
  cat "$KEYCHAIN_ADDON"
} >> "$TMP_POLICY"
fi

# Tell Playwright-backed browser automation not to re-init an inner sandbox.
export PLAYWRIGHT_MCP_SANDBOX=false

{
  cat <<EOF

;; ---------------------------------------------------------------------------
;; Launch-time workdir access
;; Generated for: ${WORKDIR}
;; ---------------------------------------------------------------------------
(allow file-read*
$(_emit_workdir_ancestors "$WORKDIR")
)
(allow file-read* file-write* (subpath "$(_sb_escape "$WORKDIR")"))
EOF
} >> "$TMP_POLICY"

# When running inside a linked git worktree, also allow read access to the
# main worktree so cross-worktree diff/inspect workflows can see the baseline.
MAIN_WORKTREE="$(_detect_main_worktree)"
if [[ -n "$MAIN_WORKTREE" ]]; then
{
  cat <<EOF

;; ---------------------------------------------------------------------------
;; Main worktree read access (linked worktree detected)
;; Main worktree: ${MAIN_WORKTREE}
;; ---------------------------------------------------------------------------
(allow file-read*
$(_emit_workdir_ancestors "$MAIN_WORKTREE")
)
(allow file-read* (subpath "$(_sb_escape "$MAIN_WORKTREE")"))
EOF
} >> "$TMP_POLICY"
fi

exec sandbox-exec -f "$TMP_POLICY" -- pi "$@"
