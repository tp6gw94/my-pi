{
  "lastChangelogVersion": "0.80.2",
  "defaultProvider": "neuralwatt",
  "defaultModel": "glm-5.2-short",
  "defaultThinkingLevel": "high",
  "packages": [
    "npm:pi-subagents",
    "npm:pi-intercom",
    "npm:pi-web-access",
    "npm:pi-mcp-adapter",
    "git:github.com/DietrichGebert/ponytail",
    "extensions/neuralwatt-provider"
  ],
  "theme": "github-light",
  "subagents": {
    "agentOverrides": {
      "scout": {
        "model": "neuralwatt/qwen3.6-35b-fast",
        "thinking": "medium"
      },
      "researcher": {
        "model": "deepseek/deepseek-v4-flash",
        "thinking": "medium"
      },
      "planner": {
        "model": "neuralwatt/glm-5.2-short",
        "thinking": "high"
      },
      "worker": {
        "model": "kimi-coding/kimi-for-coding",
        "thinking": "medium"
      }
    }
  }
}
