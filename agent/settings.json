{
  "lastChangelogVersion": "0.80.2",
  "defaultProvider": "neuralwatt",
  "defaultModel": "kimi-k2.7-code",
  "defaultThinkingLevel": "high",
  "packages": [
    "npm:pi-subagents",
    "npm:pi-intercom",
    "npm:pi-web-access",
    "npm:pi-mcp-adapter",
    "git:github.com/DietrichGebert/ponytail",
    "extensions/neuralwatt-provider",
    "extensions/deepinfra-provider",
    "git:github.com/nicobailon/visual-explainer"
  ],
  "theme": "github-light",
  "subagents": {
    "agentOverrides": {
      "scout": {
        "model": "neuralwatt/qwen3.6-35b-fast",
        "thinking": "medium"
      },
      "researcher": {
        "model": "deepinfra/deepseek-ai/DeepSeek-V4-Flash",
        "thinking": "medium"
      },
      "planner": {
        "model": "deepinfra/zai-org/GLM-5.2",
        "thinking": "high"
      },
      "reviewer": {
        "model": "deepinfra/XiaomiMiMo/MiMo-V2.5-Pro",
        "thinking": "high"
      },
      "oracle": {
        "model": "deepinfra/deepseek-ai/DeepSeek-V4-Pro",
        "thinking": "high"
      },
      "worker": {
        "model": "deepinfra/deepseek-ai/DeepSeek-V4-Flash",
        "thinking": "medium"
      },
      "context-builder": {
        "model": "neuralwatt/qwen3.5-397b",
        "thinking": "medium"
      }
    }
  }
}