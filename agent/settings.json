{
  "lastChangelogVersion": "0.80.2",
  "defaultProvider": "deepinfra",
  "defaultModel": "XiaomiMiMo/MiMo-V2.5",
  "defaultThinkingLevel": "high",
  "packages": [
    "npm:pi-subagents",
    "npm:pi-intercom",
    "npm:pi-web-access",
    "npm:pi-mcp-adapter",
    "git:github.com/DietrichGebert/ponytail",
    "extensions/neuralwatt-provider",
    "extensions/deepinfra-provider"
  ],
  "theme": "github-light",
  "subagents": {
    "agentOverrides": {
      "scout": {
        "model": "neuralwatt/qwen3.6-35b-fast",
        "thinking": "medium"
      },
      "researcher": {
        "model": "deepinfra/deepseek-ai/DeepSeek-V4-Flash",
        "thinking": "medium"
      },
      "planner": {
        "model": "neuralwatt/glm-5.2-short",
        "thinking": "high"
      },
      "reviewer": {
        "model": "deepinfra/XiaomiMiMo/MiMo-V2.5-Pro",
        "thinking": "high"
      },
      "oracle": {
        "model": "deepinfra/deepseek-ai/DeepSeek-V4-Pro",
        "thinking": "high"
      },
      "worker": {
        "model": "deepinfra/deepseek-ai/DeepSeek-V4-Flash",
        "thinking": "medium"
      }
    }
  }
}
